{
  "code-runner.executorMap": {
    "javascript": "node",
    "typescript": "node --loader tsx"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "files.exclude": {
    ".claude": true,
    "coverage": true,
    "dist": true,
    "LICENSE": true,
    "mise.toml": true,
    "node_modules": true,
    "package-lock.json": true
  }
}
