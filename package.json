{
  "type": "module",
  "name": "apigen-ts",
  "version": "1.3.0",
  "license": "MIT",
  "author": "vladkens <v.pronsky@gmail.com>",
  "repository": "vladkens/apigen-ts",
  "description": "Simple typed OpenAPI client generator",
  "keywords": [
    "openapi",
    "swagger",
    "typescript",
    "api",
    "generator",
    "codegen"
  ],
  "scripts": {
    "build": "rm -rf dist && pkgroll && cp ./src/_template.ts ./dist && ls -lah dist",
    "test": "tsx --test --test-reporter=dot test/*.test.ts",
    "test-cov": "tsx --experimental-test-coverage --test test/*.test.ts",
    "format": "prettier --write --log-level warn .",
    "ci": "tsc --noEmit && npm run test-cov && npm run build"
  },
  "dependencies": {
    "@redocly/openapi-core": "2.21.1",
    "@types/lodash-es": "4.17.12",
    "@types/swagger2openapi": "7.0.4",
    "array-utils-ts": "1.1.0",
    "cleye": "2.3.0",
    "lodash-es": "4.17.23",
    "swagger2openapi": "7.0.8"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "fetch-mock": "12.6.0",
    "tsx": "4.21.0",
    "pkgroll": "2.27.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/main.js",
  "types": "./dist/main.d.cts",
  "exports": {
    "require": {
      "types": "./dist/main.d.cts",
      "default": "./dist/main.cjs"
    },
    "import": {
      "types": "./dist/main.d.mts",
      "default": "./dist/main.mjs"
    }
  },
  "bin": {
    "apigen-ts": "./dist/cli.js"
  }
}
